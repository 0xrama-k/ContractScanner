# Server
BIND_ADDR=127.0.0.1:8080
RUST_LOG=contract_scanner=debug,tower_http=debug,info

# Database (added in milestone 2)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/contract_scanner

# LLM (bounded reporting layer). When LLM_API_KEY is unset, the layer is
# disabled and reports use Slither-only text.
# LLM_API_KEY=
# LLM_BASE_URL=https://api.intelligence.io.solutions/api/v1
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# LLM_SOURCE_CHAR_LIMIT=45000
# LLM_TIMEOUT_SECS=30

# Payment gate — Circle USDC on Arc testnet (added in milestone "Payment gate")
# On Arc, USDC is the native asset, so the scan fee is paid as native value.
# SCAN_PRICE_WEI is in 18-decimal native USDC base units: 10 USDC = 10e18.
# PAYMENT_CONTRACT_ADDRESS=
# ARC_RPC_HTTP_URL=https://rpc.testnet.arc.network
# CHAIN_ID=5042002
# SCAN_PRICE_WEI=10000000000000000000
# PAYMENT_CONFIRMATIONS=2
# PAYMENT_POLL_INTERVAL_SECS=5
# PAYMENT_WINDOW_SECS=1800
# PAYMENT_BYPASS=true

# Contract deployment (dev-only deployer; never commit the real key)
# DEPLOYER_PRIVATE_KEY=
# DEPLOYER_ADDRESS=

# Slither sandbox
# DOCKER_BIN=docker
# SLITHER_IMAGE=contract-scanner-slither:latest
# SLITHER_TIMEOUT_SECS=60

# Abuse prevention
# RATE_LIMIT_PER_HOUR=5
# MAX_CONCURRENT_SCANS=4
# IDEMPOTENCY_WINDOW_SECS=60
# IP_HASH_SALT=change-me-in-prod
