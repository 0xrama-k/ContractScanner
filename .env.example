# Server
BIND_ADDR=127.0.0.1:8080
RUST_LOG=contract_scanner=debug,tower_http=debug,info

# Database (added in milestone 2)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/contract_scanner

# LLM (bounded reporting layer; added later)
# LLM_API_KEY=
# LLM_MODEL=
# LLM_SOURCE_CHAR_LIMIT=45000
# LLM_TIMEOUT_SECS=30

# Payment gate (Monad testnet; added in milestone "Payment gate")
# PAYMENT_CONTRACT_ADDRESS=
# MONAD_RPC_WS_URL=
# MONAD_RPC_HTTP_URL=
# CHAIN_ID=10143
# SCAN_PRICE_WEI=10000000000000000000
# PAYMENT_CONFIRMATIONS=2
# PAYMENT_WINDOW_SECS=1800
# PAYMENT_BYPASS=true

# Slither sandbox
# DOCKER_BIN=docker
# SLITHER_IMAGE=contract-scanner-slither:latest
# SLITHER_TIMEOUT_SECS=60

# Abuse prevention
# RATE_LIMIT_PER_HOUR=5
# MAX_CONCURRENT_SCANS=4
# IDEMPOTENCY_WINDOW_SECS=60
# IP_HASH_SALT=change-me-in-prod
